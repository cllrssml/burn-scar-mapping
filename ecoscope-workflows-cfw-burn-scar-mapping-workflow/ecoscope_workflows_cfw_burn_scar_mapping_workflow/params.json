          "title": " ",
          "type": "array",
          "description": "Select tile layers to use as base layers in map outputs. The first layer in the list will be the bottommost layer displayed.",
          "ecoscope:advanced": true
        }
      },
      "type": "object",
      "required": [],
      "title": "Base Maps"
    },
    "burn_scar_result": {
      "additionalProperties": false,
      "properties": {
        "fire_start_date": {
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "title": "Fire Start Date",
          "type": "string",
          "description": "Start date of the fire event or scan window (YYYY-MM-DD). The pre-fire composite uses imagery before this date."
        },
        "fire_end_date": {
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "title": "Fire End Date",
          "type": "string",
          "description": "End date of the fire event or scan window (YYYY-MM-DD). Set the same as Fire Start Date for a single-day event. The post-fire composite uses imagery after this date."
        },
        "pre_fire_days": {
          "default": 90,
          "maximum": 365,
          "minimum": 30,
          "title": "Pre-Fire Window (days)",
          "type": "integer",
          "description": "Days before Fire Start Date for the pre-fire Sentinel-2 mean composite. 90\u2013120 days captures stable vegetation state before fire season onset."
        },
        "post_fire_days": {
          "default": 30,
          "maximum": 90,
          "minimum": 7,
          "title": "Post-Fire Window (days)",
          "type": "integer",
          "description": "Days after Fire End Date for the post-fire Sentinel-2 mean composite. 14\u201330 days recommended \u2014 C4 grasses in the Lowveld can recover within 2\u20134 weeks of rainfall. Use up to 60 days for dry-season fires where regrowth is slow."
        },
        "dnbr_threshold": {
          "default": 0.2,
          "maximum": 0.5,
          "minimum": 0.05,
          "title": "dNBR Detection Threshold",
          "type": "number",
          "description": "Minimum dNBR to classify a pixel as burned. Default 0.2 (200 on \u00d71000 scale). 0.1 detects more area but increases false positives from vegetation drying. 0.27\u20130.3 gives high-confidence detections but may miss low-severity burns."
        },
        "scale": {
          "default": 20,
          "maximum": 200,
          "minimum": 10,
          "title": "Analysis Scale (metres)",
          "type": "integer",
          "description": "Pixel resolution for dNBR computation. Native Sentinel-2 SWIR resolution is 20 m. Increase for large AOIs to reduce computation time."
        }
      },
      "required": [
        "fire_start_date",
        "fire_end_date"
      ],
      "type": "object",
      "title": "Compute Burn Scar"
    },
    "burn_scar_layer": {
      "additionalProperties": false,
      "properties": {
        "opacity": {
          "default": 0.85,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Layer Opacity",
          "type": "number",
          "description": "Transparency of the burn scar layer (0 = transparent, 1 = fully opaque)."
        }
      },
      "required": [],
      "type": "object",
      "title": "Burn Scar Layer"
    }
  },
  "$defs": {
    "EarthRangerConnection": {
      "properties": {
        "name": {
          "title": "Data Source",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "EarthRangerConnection",
      "type": "object"
    },
    "GoogleEarthEngineConnection": {
      "properties": {
        "name": {
          "title": "Data Source",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "GoogleEarthEngineConnection",
      "type": "object"
    }
  },
  "uiSchema": {
    "workflow_details": {
      "ui:order": [
        "name",
        "description"
      ]
    },
    "burn_scar_result": {
      "ui:order": [
        "fire_start_date",
        "fire_end_date",
        "pre_fire_days",
        "post_fire_days",
        "dnbr_threshold",
        "scale"
      ]
    },
    "ui:order": [
      "workflow_details",
      "er_connection",
      "gee_connection",
      "aoi_name",
      "overlay_name",
      "base_maps",
      "burn_scar_result",
      "burn_scar_layer"
    ]
  },
  "additionalProperties": false
