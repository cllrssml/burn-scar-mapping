{
  "properties": {
    "workflow_details": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "title": "Workflow Name",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Workflow Description",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object",
      "description": "Add information that will help to differentiate this workflow from another.",
      "title": "Workflow Details"
    },
    "er_connection": {
      "additionalProperties": false,
      "properties": {
        "data_source": {
          "$ref": "#/$defs/EarthRangerConnection",
          "title": "",
          "description": "Select one of your configured data sources."
        }
      },
      "required": [
        "data_source"
      ],
      "type": "object",
      "title": "EarthRanger"
    },
    "gee_connection": {
      "additionalProperties": false,
      "properties": {
        "data_source": {
          "$ref": "#/$defs/GoogleEarthEngineConnection",
          "title": "",
          "description": "Select one of your configured data sources."
        }
      },
      "required": [
        "data_source"
      ],
      "type": "object",
      "title": "Earth Engine"
    },
    "aoi_name": {
      "additionalProperties": false,
      "properties": {
        "group_name": {
          "title": "AOI Group Name",
          "type": "string",
          "description": "Name of an EarthRanger spatial features group that defines the area to scan for burn scars (e.g. 'Reserve Boundary', 'North Block'). Find it in ER under Admin \u2192 Map Layers \u2192 Feature Groups. The burn detection will be run within this boundary."
        }
      },
      "required": [
        "group_name"
      ],
      "type": "object",
      "title": "AOI Name"
    },
    "overlay_name": {
      "additionalProperties": false,
      "properties": {
        "group_name": {
          "default": "",
          "title": "Overlay Layer Group Name",
          "type": "string",
          "description": "Optional: name of an EarthRanger spatial features group to display as an extra layer on the map (e.g. 'Roads', 'Fencelines', 'Water Sources'). Leave blank to add no overlay."
        }
      },
      "type": "object",
      "required": [],
      "title": "Overlay Layer Group Name"
    },
    "base_maps": {
